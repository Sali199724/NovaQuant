# .env.example
# NovaQuant Environment Variables Example File
# Save a copy of this file as .env and fill in the values.
# Do not commit real credentials or secrets to this file.

# Gemini API Key (Server-side AI Engine calls)
GEMINI_API_KEY=

# Anthropic API Key (Server-side Claude sonnet calls)
ANTHROPIC_API_KEY=

# App Hosting URL
APP_URL=

# SMTP Mail Server Configuration
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
SMTP_SECURE=

# Binance Futures API Keys
BINANCE_API_KEY=
BINANCE_SECRET_KEY=
BINANCE_ENCRYPTION_SECRET=
BINANCE_API_URL=
BINANCE_IS_TESTNET=true

# JWT Secret Keys
JWT_SECRET=

# Firebase Client SDK Credentials
VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=
VITE_FIREBASE_MEASUREMENT_ID=

# EmailJS Client Credentials
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Cloud SQL PostgreSQL Database Credentials
SQL_HOST=
SQL_DB_NAME=
SQL_USER=
SQL_PASSWORD=
SQL_ADMIN_USER=
SQL_ADMIN_PASSWORD=

# Server Public Egress Static IP (Optional for Cloud Run with Cloud NAT setup)
SERVER_PUBLIC_IP=
